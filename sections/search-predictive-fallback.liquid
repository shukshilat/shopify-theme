{% comment %}
  Predictive Search API does not support Hebrew — the storefront search still works.
  search.results must be iterated inside {% paginate %} or the array may be empty.
  Section Rendering: GET /search?q=...&type=product&options[prefix]=last&section_id=search-predictive-fallback
  List this section in templates/search.json or Section Rendering returns 404.
  Output dropdown markup only when query includes search-predictive-fallback (AJAX), not on full-page search.
{% endcomment %}
{%- liquid
  assign spf_section_render = false
  if request.query_string contains 'search-predictive-fallback'
    assign spf_section_render = true
  endif
-%}
{%- if spf_section_render and search.terms != blank -%}
  {% paginate search.results by 10 %}
    {%- liquid
      assign fallback_count = 0
      for item in search.results
        if item.object_type == 'product'
          assign fallback_count = fallback_count | plus: 1
        endif
      endfor
    -%}
    <div id="predictive-search-results" role="listbox">
      {%- if fallback_count > 0 -%}
        <div
          id="predictive-search-results-groups-wrapper"
          class="predictive-search__results-groups-wrapper predictive-search__results-groups-wrapper--no-suggestions"
        >
          <div class="predictive-search__result-group">
            <div>
              <h2
                id="predictive-search-products"
                class="predictive-search__heading text-body caption-with-letter-spacing"
              >
                {{- 'templates.search.products' | t -}}
              </h2>
              <ul
                id="predictive-search-results-products-list"
                class="predictive-search__results-list list-unstyled"
                role="group"
                aria-labelledby="predictive-search-products"
              >
                {%- for item in search.results -%}
                  {%- if item.object_type == 'product' -%}
                    {%- assign product = item -%}
                    <li
                      id="predictive-search-option-product-{{ forloop.index }}"
                      class="predictive-search__list-item"
                      role="option"
                      aria-selected="false"
                    >
                      <a
                        href="{{ product.url }}"
                        class="predictive-search__item predictive-search__item--link-with-thumbnail link link--text"
                        tabindex="-1"
                      >
                        {%- if product.featured_media != blank -%}
                          <img
                            class="predictive-search__image"
                            src="{{ product.featured_media | image_url: width: 150 }}"
                            alt="{{ product.featured_media.alt | escape }}"
                            width="50"
                            height="{{ 50 | divided_by: product.featured_media.preview_image.aspect_ratio }}"
                          >
                        {%- endif -%}
                        <div class="predictive-search__item-content{% unless settings.predictive_search_show_vendor or settings.predictive_search_show_price %} predictive-search__item-content--centered{% endunless %}">
                          {%- if settings.predictive_search_show_vendor -%}
                            <span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
                            <div class="predictive-search__item-vendor caption-with-letter-spacing">
                              {{ product.vendor }}
                            </div>
                          {%- endif -%}
                          <p class="predictive-search__item-heading h5">{{ product.title | escape }}</p>
                          {%- if settings.predictive_search_show_price -%}
                            {% render 'price',
                              product: product,
                              use_variant: true,
                              show_badges: false,
                              unit_price_only: true
                            %}
                          {%- endif -%}
                        </div>
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}

      <div id="predictive-search-option-search-keywords" class="predictive-search__search-for-button">
        <button
          class="predictive-search__item predictive-search__item--term link link--text h5 animate-arrow"
          tabindex="-1"
          role="option"
          aria-selected="false"
        >
          <span data-predictive-search-search-for-text>
            {{- 'templates.search.search_for' | t: terms: search.terms -}}
          </span>
          <span class="svg-wrapper">
            {{- 'icon-arrow.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>
    </div>

    <span class="hidden" data-predictive-search-live-region-count-value>
      {%- if fallback_count > 0 -%}
        {{- 'templates.search.results_with_count' | t: count: fallback_count -}}
      {%- else -%}
        {{- 'templates.search.no_results' | t: terms: search.terms -}}
      {%- endif -%}
    </span>
  {% endpaginate %}
{%- else -%}
  <div class="spf-placeholder" hidden style="display:none" aria-hidden="true"></div>
{%- endif -%}

{% schema %}
{
  "name": "Search fallback",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
