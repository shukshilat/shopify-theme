{%- style -%}
  .home-bottom-footer-{{ section.id }} {
    --footer-card-bg: linear-gradient(
      135deg,
      rgba(var(--color-background), 0.96) 0%,
      rgba(var(--color-background), 0.86) 100%
    );
    --footer-accent: rgba(var(--color-button), 1);
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background:
      radial-gradient(circle at 85% 15%, rgba(var(--color-button), 0.16), transparent 45%),
      radial-gradient(circle at 15% 85%, rgba(var(--color-foreground), 0.08), transparent 40%),
      rgb(var(--color-background));
    border-top: 1px solid rgba(var(--color-foreground), 0.16);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.8rem;
    align-items: stretch;
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__card {
    position: relative;
    border-radius: 1.6rem;
    padding: 2rem 1.8rem;
    background: var(--footer-card-bg);
    border: 1px solid rgba(var(--color-foreground), 0.1);
    box-shadow: 0 0.8rem 2.4rem rgba(0, 0, 0, 0.1);
    backdrop-filter: blur(3px);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__about-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 100%;
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__label {
    margin: 0;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.65);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.8rem;
    min-width: 17rem;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-button-text), 0.1);
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    box-shadow: 0 0.8rem 1.8rem rgba(var(--color-button), 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 1rem 2rem rgba(var(--color-button), 0.45);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__btn:focus-visible {
    outline: 0.2rem solid var(--footer-accent);
    outline-offset: 0.2rem;
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__branches {
    text-align: center;
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.8rem;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(var(--color-button));
    background: rgba(var(--color-button), 0.12);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__title {
    margin: 0 0 0.7rem;
    font-size: 2rem;
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__text {
    margin: 0;
    line-height: 1.8;
    font-size: 1.45rem;
    color: rgba(var(--color-foreground), 0.88);
  }

  .home-bottom-footer-{{ section.id }} .home-bottom-footer__text p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .home-bottom-footer-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .home-bottom-footer-{{ section.id }} .home-bottom-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .home-bottom-footer-{{ section.id }} .home-bottom-footer__about-wrap {
      align-items: flex-start;
      text-align: right;
    }

    .home-bottom-footer-{{ section.id }} .home-bottom-footer__branches {
      text-align: end;
    }
  }
{%- endstyle -%}

<section class="home-bottom-footer-{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="page-width home-bottom-footer__inner">
    <div class="home-bottom-footer__card home-bottom-footer__about">
      <div class="home-bottom-footer__about-wrap">
        <p class="home-bottom-footer__label">about</p>
        <a
          class="home-bottom-footer__btn"
          href="{{ section.settings.about_link }}"
        >
          {{ section.settings.about_label | escape }}
        </a>
      </div>
    </div>

    <div class="home-bottom-footer__card home-bottom-footer__branches">
      <span class="home-bottom-footer__pill">branches</span>
      <h2 class="home-bottom-footer__title">{{ section.settings.branches_title | escape }}</h2>
      <div class="home-bottom-footer__text rte">
        {{ section.settings.branches_text }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home bottom footer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "about_label",
      "label": "About button label",
      "default": "אודות האתר"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "About button link"
    },
    {
      "type": "text",
      "id": "branches_title",
      "label": "Branches title",
      "default": "הסניפים שלנו ושעות פתיחה"
    },
    {
      "type": "richtext",
      "id": "branches_text",
      "label": "Branches and hours text",
      "default": "<p>מודיעין - עמק דותן 66<br/>א'-ה' 08:00-20:00<br/>ו' 08:00-14:30</p>"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Home bottom footer"
    }
  ]
}
{% endschema %}
