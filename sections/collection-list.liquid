{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Shorter media area so titles sit closer to category images */
  .collection-list-wrapper.section-{{ section.id }}-padding .card__inner.ratio {
    --ratio-percent: 56% !important;
  }

  @media screen and (min-width: 750px) {
    .collection-list-wrapper.section-{{ section.id }}-padding .card__inner.ratio {
      --ratio-percent: 56% !important;
    }
  }

  @media screen and (min-width: 990px) {
    .collection-list-wrapper.section-{{ section.id }}-padding .collection-list.grid--3-col-desktop:not(.slider) {
      max-width: min(100%, 110rem);
      margin-inline: auto;
    }
  }
{%- endstyle -%}

{%- liquid
  assign use_menu_list = false
  if section.settings.list_source == 'menu' and section.settings.menu != blank
    assign use_menu_list = true
  endif

  assign list_items_count = section.blocks.size
  if use_menu_list
    assign list_items_count = 0
    for link in section.settings.menu.links
      if link.links != blank
        for childlink in link.links
          if childlink.type == 'collection_link'
            assign list_items_count = list_items_count | plus: 1
          elsif childlink.links != blank
            for gl in childlink.links
              if gl.type == 'collection_link'
                assign list_items_count = list_items_count | plus: 1
              endif
            endfor
          endif
        endfor
      elsif link.type == 'collection_link'
        assign list_items_count = list_items_count | plus: 1
      else
        assign link_title_d = link.title | downcase
        if link_title_d contains 'ביצים'
          assign e_t = blank
          assign e_o = blank
          assign e_b = blank
          assign e_g = blank
          for c in collections
            assign ct = c.title | strip
            if e_t == blank and ct == 'תבליני פרג'
              assign e_t = c
            endif
            if e_o == blank and ct == 'שמן זית'
              assign e_o = c
            endif
            if e_b == blank and ct == 'ביצים'
              assign e_b = c
            endif
            if e_b == blank and ct == 'ביצי חופש'
              assign e_b = c
            endif
            if e_g == blank and ct == 'מוצרי מרכול'
              assign e_g = c
            endif
          endfor
          if e_t != blank
            assign list_items_count = list_items_count | plus: 1
          endif
          if e_o != blank
            assign list_items_count = list_items_count | plus: 1
          endif
          if e_b != blank
            assign list_items_count = list_items_count | plus: 1
          endif
          if e_g != blank
            assign list_items_count = list_items_count | plus: 1
          endif
        endif
      endif
    endfor
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0
  assign show_mobile_slider = false
  assign show_desktop_slider = false
  if section.settings.enable_carousel
    if list_items_count > columns_mobile_int
      assign show_mobile_slider = true
    endif
    if list_items_count > columns_desktop_int
      assign show_desktop_slider = true
    endif
  elsif section.settings.swipe_on_mobile and list_items_count > columns_mobile_int
    assign show_mobile_slider = true
  endif
  assign show_any_slider = false
  if show_mobile_slider or show_desktop_slider
    assign show_any_slider = true
  endif
  assign section_color_scheme = section.settings.color_scheme
  if section_color_scheme == blank
    assign section_color_scheme = 'scheme-1'
  endif
-%}

<div class="color-{{ section_color_scheme }} gradient">
  <div class="collection-list-wrapper page-width isolate{% if show_any_slider %} page-width-desktop{% endif %}{% if section.settings.title == blank %} no-heading{% endif %}{% if section.settings.show_view_all == false or list_items_count > collections.size %} no-mobile-link{% endif %} section-{{ section.id }}-padding">
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link{% if show_any_slider %} title-wrapper--self-padded-tablet-down{% else %} title-wrapper--self-padded-mobile{% endif %} title-wrapper--no-top-margin{% if show_desktop_slider %} collection-list__title--carousel{% endif %}">
        <h2
          id="SectionHeading-{{ section.id }}"
          class="collection-list-title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        >
          {{ section.settings.title }}
        </h2>

        {%- if section.settings.show_view_all and show_any_slider -%}
          <a
            href="{{ routes.collections_url }}"
            id="ViewAll-{{ section.id }}"
            class="link underlined-link large-up-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}"
          >
            {{- 'sections.collection_list.view_all' | t -}}
          </a>
        {%- endif -%}
      </div>
    {%- endunless -%}

    <slider-component class="slider-mobile-gutter{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <ul
        class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %} collection-list--{{ list_items_count }}-items"
        id="Slider-{{ section.id }}"
        role="list"
        aria-label="{{ section.settings.title | default: shop.name | escape }}"
      >
        {%- liquid
          assign columns = list_items_count
          if columns > 3
            assign columns = 3
          endif
        -%}
        {%- if use_menu_list -%}
          {%- assign menu_slide_idx = 0 -%}
          {%- assign menu_anim = 0 -%}
          {%- for link in section.settings.menu.links -%}
            {%- if link.links != blank -%}
              {%- for childlink in link.links -%}
                {%- if childlink.type == 'collection_link' -%}
                  {%- assign menu_slide_idx = menu_slide_idx | plus: 1 -%}
                  {%- assign menu_anim = menu_anim | plus: 1 -%}
                  <li
                    id="Slide-{{ section.id }}-{{ menu_slide_idx }}"
                    class="collection-list__item grid__item{% if show_any_slider %} slider__slide{% endif %}{% if childlink.object.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ menu_anim }};"
                    {% endif %}
                  >
                    {%- assign placeholder_image_index = menu_slide_idx | modulo: 4 | plus: 1 -%}
                    {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                    {% render 'card-collection',
                      card_collection: childlink.object,
                      media_aspect_ratio: section.settings.image_ratio,
                      columns: columns,
                      placeholder_image: placeholder_image
                    %}
                  </li>
                {%- elsif childlink.links != blank -%}
                  {%- for gl in childlink.links -%}
                    {%- if gl.type == 'collection_link' -%}
                      {%- assign menu_slide_idx = menu_slide_idx | plus: 1 -%}
                      {%- assign menu_anim = menu_anim | plus: 1 -%}
                      <li
                        id="Slide-{{ section.id }}-{{ menu_slide_idx }}"
                        class="collection-list__item grid__item{% if show_mobile_slider %} slider__slide{% endif %}{% if gl.object.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                          style="--animation-order: {{ menu_anim }};"
                        {% endif %}
                      >
                        {%- assign placeholder_image_index = menu_slide_idx | modulo: 4 | plus: 1 -%}
                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                        {% render 'card-collection',
                          card_collection: gl.object,
                          media_aspect_ratio: section.settings.image_ratio,
                          columns: columns,
                          placeholder_image: placeholder_image
                        %}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            {%- elsif link.type == 'collection_link' -%}
              {%- assign menu_slide_idx = menu_slide_idx | plus: 1 -%}
              {%- assign menu_anim = menu_anim | plus: 1 -%}
              <li
                id="Slide-{{ section.id }}-{{ menu_slide_idx }}"
                class="collection-list__item grid__item{% if show_any_slider %} slider__slide{% endif %}{% if link.object.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ menu_anim }};"
                {% endif %}
              >
                {%- assign placeholder_image_index = menu_slide_idx | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                {% render 'card-collection',
                  card_collection: link.object,
                  media_aspect_ratio: section.settings.image_ratio,
                  columns: columns,
                  placeholder_image: placeholder_image
                %}
              </li>
            {%- else -%}
              {%- assign link_title_d2 = link.title | downcase -%}
              {%- if link_title_d2 contains 'ביצים' -%}
                {% render 'collection-list-eggs-cluster-items',
                  section_id: section.id,
                  columns: columns,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_mobile_slider: show_mobile_slider,
                  animation_base: menu_anim
                %}
                {%- assign menu_anim = menu_anim | plus: 4 -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="collection-list__item grid__item{% if show_any_slider %} slider__slide{% endif %}{% if block.settings.collection.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
              {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
              {% render 'card-collection',
                card_collection: block.settings.collection,
                media_aspect_ratio: section.settings.image_ratio,
                columns: columns,
                placeholder_image: placeholder_image
              %}
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
      {%- if show_any_slider -%}
        <div class="slider-buttons collection-list__slider-buttons--arrows-only">
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>

    {%- if section.settings.show_view_all and list_items_count < collections.size -%}
      <div
        class="center collection-list-view-all{% if show_any_slider %} small-hide medium-hide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        <a
          href="{{ routes.collections_url }}"
          class="button"
          id="ViewAllButton-{{ section.id }}"
          aria-labelledby="ViewAllButton-{{ section.id }} SectionHeading-{{ section.id }}"
        >
          {{- 'sections.collection_list.view_all' | t -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.collection-list.name",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "list_source",
      "options": [
        {
          "value": "blocks",
          "label": "t:sections.collection-list.settings.list_source.options__1.label"
        },
        {
          "value": "menu",
          "label": "t:sections.collection-list.settings.list_source.options__2.label"
        }
      ],
      "default": "blocks",
      "label": "t:sections.collection-list.settings.list_source.label"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.collection-list.settings.menu.label",
      "info": "t:sections.collection-list.settings.menu.info"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.collection-list.settings.title.default",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header_layout.content"
    },    
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.collection-list.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.collection-list.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.collection-list.settings.image_ratio.options__3.label"
        }
      ],
      "default": "square",
      "label": "t:sections.collection-list.settings.image_ratio.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.collection-list.settings.columns_desktop.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": false,
      "label": "t:sections.collection-list.settings.show_view_all.label",
      "info": "t:sections.collection-list.settings.show_view_all.info"   
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "default": true,
      "label": "t:sections.collection-list.settings.enable_carousel.label",
      "info": "t:sections.collection-list.settings.enable_carousel.info"
    },
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.collection-list.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.collection-list.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.collection-list.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.collection-list.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "t:sections.collection-list.blocks.featured_collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.collection.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-list.presets.name",
      "blocks": [
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        }
      ]
    }
  ]
}
{% endschema %}

