    {%- else -%}
      שמן זית
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if section.settings.eggs_subcat_free_eggs != blank %}{{ section.settings.eggs_subcat_free_eggs.url }}{% else %}/search?q={{ 'ביצי חופש' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
