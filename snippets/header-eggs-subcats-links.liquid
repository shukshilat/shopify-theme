{% comment %}
  Sub-links for "ביצים, שמן זית ועוד".
  1) Uses collection objects from Header settings when set in the theme editor.
  2) If blank, finds store collections by exact title (works without theme editor picks).
  Parents must pass: eggs_subcat_tavlinim, eggs_subcat_olive_oil, eggs_subcat_free_eggs, eggs_subcat_grocery
  Param: link_class (required)
{% endcomment %}
{%- assign eggs_subcat_tavlinim_resolved = eggs_subcat_tavlinim -%}
{%- assign eggs_subcat_olive_oil_resolved = eggs_subcat_olive_oil -%}
{%- assign eggs_subcat_free_eggs_resolved = eggs_subcat_free_eggs -%}
{%- assign eggs_subcat_grocery_resolved = eggs_subcat_grocery -%}
{%- if eggs_subcat_tavlinim_resolved == blank or eggs_subcat_olive_oil_resolved == blank or eggs_subcat_free_eggs_resolved == blank or eggs_subcat_grocery_resolved == blank -%}
  {%- for c in collections -%}
    {%- assign t = c.title | strip -%}
    {%- if eggs_subcat_tavlinim_resolved == blank and t == 'תבליני פרג' -%}
      {%- assign eggs_subcat_tavlinim_resolved = c -%}
    {%- endif -%}
    {%- if eggs_subcat_olive_oil_resolved == blank and t == 'שמן זית' -%}
      {%- assign eggs_subcat_olive_oil_resolved = c -%}
    {%- endif -%}
    {%- if eggs_subcat_free_eggs_resolved == blank and t == 'ביצים' -%}
      {%- assign eggs_subcat_free_eggs_resolved = c -%}
    {%- endif -%}
    {%- if eggs_subcat_free_eggs_resolved == blank and t == 'ביצי חופש' -%}
      {%- assign eggs_subcat_free_eggs_resolved = c -%}
    {%- endif -%}
    {%- if eggs_subcat_grocery_resolved == blank and t == 'מוצרי מרכול' -%}
      {%- assign eggs_subcat_grocery_resolved = c -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
<li>
  <a
    href="{% if eggs_subcat_tavlinim_resolved != blank %}{{ eggs_subcat_tavlinim_resolved.url }}{% else %}/search?q={{ 'תבליני פרג' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_tavlinim_resolved != blank -%}
      {{- eggs_subcat_tavlinim_resolved.title | escape -}}
    {%- else -%}
      תבליני פרג
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if eggs_subcat_olive_oil_resolved != blank %}{{ eggs_subcat_olive_oil_resolved.url }}{% else %}/search?q={{ 'שמן זית' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_olive_oil_resolved != blank -%}
      {{- eggs_subcat_olive_oil_resolved.title | escape -}}
    {%- else -%}
      שמן זית
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if eggs_subcat_free_eggs_resolved != blank %}{{ eggs_subcat_free_eggs_resolved.url }}{% else %}/search?q={{ 'ביצי חופש' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_free_eggs_resolved != blank -%}
      {{- eggs_subcat_free_eggs_resolved.title | escape -}}
    {%- else -%}
      ביצי חופש
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if eggs_subcat_grocery_resolved != blank %}{{ eggs_subcat_grocery_resolved.url }}{% else %}/search?q={{ 'מוצרי מרכול' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_grocery_resolved != blank -%}
      {{- eggs_subcat_grocery_resolved.title | escape -}}
    {%- else -%}
      מוצרי מרכול
    {%- endif -%}
  </a>
</li>
