{% comment %}
  Sub-links for "ביצים, שמן זית ועוד" — collection URLs from Header section settings.
  Snippets nested inside snippets do NOT inherit `section`; callers must pass these:
  eggs_subcat_tavlinim, eggs_subcat_olive_oil, eggs_subcat_free_eggs, eggs_subcat_grocery
  Param: link_class (required) — CSS classes for the inner <a>
{% endcomment %}
<li>
  <a
    href="{% if eggs_subcat_tavlinim != blank %}{{ eggs_subcat_tavlinim.url }}{% else %}/search?q={{ 'תבליני פרג' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_tavlinim != blank -%}
      {{- eggs_subcat_tavlinim.title | escape -}}
    {%- else -%}
      תבליני פרג
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if eggs_subcat_olive_oil != blank %}{{ eggs_subcat_olive_oil.url }}{% else %}/search?q={{ 'שמן זית' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_olive_oil != blank -%}
      {{- eggs_subcat_olive_oil.title | escape -}}
    {%- else -%}
      שמן זית
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if eggs_subcat_free_eggs != blank %}{{ eggs_subcat_free_eggs.url }}{% else %}/search?q={{ 'ביצי חופש' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_free_eggs != blank -%}
      {{- eggs_subcat_free_eggs.title | escape -}}
    {%- else -%}
      ביצי חופש
    {%- endif -%}
  </a>
</li>
<li>
  <a
    href="{% if eggs_subcat_grocery != blank %}{{ eggs_subcat_grocery.url }}{% else %}/search?q={{ 'מוצרי מרכול' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if eggs_subcat_grocery != blank -%}
      {{- eggs_subcat_grocery.title | escape -}}
    {%- else -%}
      מוצרי מרכול
    {%- endif -%}
  </a>
</li>
