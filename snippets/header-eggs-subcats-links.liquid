{% comment %}
  Sub-links for "ביצים, שמן זית ועוד" — uses section collection settings, falls back to search.
  Params: link_class (required) — CSS classes for the inner <a>
{% endcomment %}
<li>
  <a
    href="{% if section.settings.eggs_subcat_tavlinim != blank %}{{ section.settings.eggs_subcat_tavlinim.url }}{% else %}/search?q={{ 'תבליני פרג' | url_encode }}&type=product{% endif %}"
    class="{{ link_class }}"
  >
    {%- if section.settings.eggs_subcat_tavlinim != blank -%}
      {{- section.settings.eggs_subcat_tavlinim.title | escape -}}
    {%- else -%}
      תבליני פרג
    {%- endif -%}
  </a>
</li>
