{%- liquid
  assign waze_address = 'עמק דותן 66 מודיעין'
-%}
<a
  class="floating-waze focus-inset"
  href="https://waze.com/ul?q={{ waze_address | url_encode }}&navigate=yes"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="{{ 'general.waze.open_navigation' | t }}"
>
  <span class="floating-waze__icon">
    <img
      src="{{ 'icon-waze.svg' | asset_url }}"
      alt=""
      width="34"
      height="34"
      loading="lazy"
    >
  </span>
</a>
