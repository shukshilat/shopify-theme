{% comment %}
  Bottom quantity + add to cart for product cards (single-variant products).
  Expects: product, section_id, section
{% endcomment %}
{%- liquid
  assign v = product.selected_or_first_available_variant
  assign min_q = v.quantity_rule.min
  if min_q == null or min_q < 1
    assign min_q = 1
  endif
  assign max_q = v.quantity_rule.max
  assign inc_q = v.quantity_rule.increment
  if inc_q == null or inc_q < 1
    assign inc_q = 1
  endif
  assign sell_modes = product.metafields.custom.card_sell_modes.value
  if sell_modes == blank
    assign sell_modes = 'both'
  endif
  assign show_weight = true
  assign show_unit = true
  if sell_modes == 'unit_only'
    assign show_weight = false
  elsif sell_modes == 'weight_only'
    assign show_unit = false
  endif
  assign form_id = 'CardQtyForm-' | append: section_id | append: '-' | append: product.id
  assign weight_behavior = settings.card_weight_cart_behavior | default: 'grams'
  assign max_q_str = max_q | default: ''
-%}
<div class="card-product-qty" data-card-quantity-root>
  <product-form class="card-product-qty__product-form" data-section-id="{{ section.id }}">
    {%- form 'product',
      product,
      id: form_id,
      class: 'form card-product-qty__form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form',
      data-card-quantity-form: 'true',
      data-weight-behavior: weight_behavior,
      data-qty-min: min_q,
      data-qty-increment: inc_q,
      data-qty-max: max_q_str
    -%}
      <input type="hidden" name="id" value="{{ v.id }}" class="product-variant-id" {% if v.available == false %}disabled{% endif %}>
      <input
        type="hidden"
        name="quantity"
        value="{{ min_q }}"
        class="card-product-qty__quantity-hidden"
        autocomplete="off"
      >

      {%- if show_unit and show_weight -%}
        <div class="card-product-qty__mode" role="group" aria-label="{{ 'products.product.card_quantity.mode_group' | t }}">
          <label class="card-product-qty__mode-label">
            <input type="radio" name="purchase_mode" value="unit" class="card-product-qty__mode-input" checked>
            <span>{{ 'products.product.card_quantity.by_units' | t }}</span>
          </label>
          <label class="card-product-qty__mode-label">
            <input type="radio" name="purchase_mode" value="weight" class="card-product-qty__mode-input">
            <span>{{ 'products.product.card_quantity.by_weight' | t }}</span>
          </label>
        </div>
      {%- elsif show_weight -%}
        <input type="hidden" name="purchase_mode" value="weight">
      {%- else -%}
        <input type="hidden" name="purchase_mode" value="unit">
      {%- endif -%}

      <div class="card-product-qty__panels">
        {%- if show_unit -%}
          <div class="card-product-qty__panel card-product-qty__panel--unit" data-card-panel="unit">
            <label class="visually-hidden" for="CardQtyUnit-{{ section_id }}-{{ product.id }}">
              {{- 'products.product.card_quantity.units_label' | t -}}
            </label>
            <input
              id="CardQtyUnit-{{ section_id }}-{{ product.id }}"
              type="number"
              class="field__input js-card-qty-unit"
              min="{{ min_q }}"
              {% if max_q != null %}max="{{ max_q }}"{% endif %}
              step="{{ inc_q }}"
              value="{{ min_q }}"
            >
          </div>
        {%- endif -%}
        {%- if show_weight -%}
          <div
            class="card-product-qty__panel card-product-qty__panel--weight{% if show_unit %} hidden{% endif %}"
            data-card-panel="weight"
            {% if show_unit %}hidden{% endif %}
          >
            <label class="visually-hidden" for="CardQtyKg-{{ section_id }}-{{ product.id }}">
              {{- 'products.product.card_quantity.weight_label' | t -}}
            </label>
            <div class="card-product-qty__weight-row">
              <input
                id="CardQtyKg-{{ section_id }}-{{ product.id }}"
                type="number"
                class="field__input js-card-qty-kg"
                min="0.1"
                step="0.1"
                value="1"
                inputmode="decimal"
              >
              <span class="card-product-qty__suffix" aria-hidden="true">{{ 'products.product.card_quantity.kg_suffix' | t }}</span>
            </div>
            <p class="card-product-qty__hint caption">{{ 'products.product.card_quantity.weight_hint' | t }}</p>
          </div>
        {%- endif -%}
      </div>

      <button
        type="submit"
        name="add"
        class="button button--full-width button--secondary card-product-qty__submit"
        aria-labelledby="CardQtySubmit-{{ section_id }}-{{ product.id }} title-{{ section_id }}-{{ product.id }}"
        {% if v.available == false %}
          disabled
        {% endif %}
      >
        <span id="CardQtySubmit-{{ section_id }}-{{ product.id }}">
          {%- if v.available -%}
            {{ 'products.product.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.product.sold_out' | t }}
          {%- endif -%}
        </span>
        {%- render 'loading-spinner' -%}
      </button>
    {%- endform -%}
  </product-form>
</div>
