{% comment %}
  Bottom quantity + add to cart for product cards (single-variant products).
  Expects: product, section_id, section
  Optional: card_qty_in_media — true when rendered inside .card__media-actions (compact bar on image)
{% endcomment %}
{%- liquid
  assign card_qty_in_media = card_qty_in_media | default: false, allow_false: true
  assign v = product.selected_or_first_available_variant
  assign min_q = v.quantity_rule.min
  if min_q == null or min_q < 1
    assign min_q = 1
  endif
  assign max_q = v.quantity_rule.max
  assign inc_q = v.quantity_rule.increment
  if inc_q == null or inc_q < 1
    assign inc_q = 1
  endif
  comment
    Metafield custom.card_sell_modes: unit_only | weight_only | both
    ברירת מחדל: unit_only — "לפי משקל" מוצג רק כשמגדירים במפורש both או weight_only
  endcomment
  assign sell_modes_raw = product.metafields.custom.card_sell_modes.value
  assign sell_modes = 'unit_only'
  if sell_modes_raw != blank
    assign sell_modes_try = sell_modes_raw | strip | downcase
    if sell_modes_try == 'both' or sell_modes_try == 'unit_only' or sell_modes_try == 'weight_only'
      assign sell_modes = sell_modes_try
    else
      for sell_modes_entry in sell_modes_raw
        assign sell_modes = sell_modes_entry | strip | downcase
        break
      endfor
    endif
  endif
  unless sell_modes == 'both' or sell_modes == 'unit_only' or sell_modes == 'weight_only'
    assign sell_modes = 'unit_only'
  endunless
  assign show_weight = false
  assign show_unit = true
  if sell_modes == 'weight_only'
    assign show_weight = true
    assign show_unit = false
  elsif sell_modes == 'both'
    assign show_weight = true
    assign show_unit = true
  endif
  assign form_id = 'CardQtyForm-' | append: section_id | append: '-' | append: product.id
  assign weight_behavior = settings.card_weight_cart_behavior | default: 'grams'
  assign max_q_str = max_q | default: ''

  assign cents_per_kg = 0
  if v.unit_price_measurement != blank and v.unit_price != blank
    assign ref_v = v.unit_price_measurement.reference_value | default: 1
    assign ref_u = v.unit_price_measurement.reference_unit
    assign ref_grams = 0
    if ref_u == 'kg'
      assign ref_grams = ref_v | times: 1000
    elsif ref_u == 'g'
      assign ref_grams = ref_v
    endif
    if ref_grams > 0
      assign cents_per_kg = v.unit_price | times: 1000 | divided_by: ref_grams
    endif
  endif

  assign line_unit_cents = v.price | times: min_q
  assign line_weight_cents = cents_per_kg
  if line_weight_cents == 0
    assign line_weight_cents = v.price
  endif

  assign initial_line_cents = line_unit_cents
  unless show_unit
    if show_weight
      assign initial_line_cents = line_weight_cents
    endif
  endunless

  assign compare_per_kg = 0
  if v.compare_at_price > v.price and v.unit_price_measurement != blank
    assign ref_cv = v.unit_price_measurement.reference_value | default: 1
    assign ref_cu = v.unit_price_measurement.reference_unit
    assign ref_cg = 0
    if ref_cu == 'kg'
      assign ref_cg = ref_cv | times: 1000
    elsif ref_cu == 'g'
      assign ref_cg = ref_cv
    endif
    if ref_cg > 0
      assign compare_per_kg = v.compare_at_price | times: 1000 | divided_by: ref_cg
    endif
  endif

  assign initial_compare_cents = 0
  if v.compare_at_price > v.price
    if show_weight and show_unit == false
      assign initial_compare_cents = compare_per_kg
    else
      assign initial_compare_cents = v.compare_at_price | times: min_q
    endif
  endif

  if settings.currency_code_enabled
    assign money_fmt_initial = initial_line_cents | money_with_currency
    assign money_fmt_compare = initial_compare_cents | money_with_currency
  else
    assign money_fmt_initial = initial_line_cents | money
    assign money_fmt_compare = initial_compare_cents | money
  endif
-%}
<div
  class="card-product-qty card-product-qty--premium{% if card_qty_in_media %} card-product-qty--media-bar{% endif %}"
  data-card-quantity-root
  data-show-unit="{{ show_unit }}"
  data-show-weight="{{ show_weight }}"
>
  <product-form class="card-product-qty__product-form" data-section-id="{{ section.id }}">
    {%- form 'product',
      product,
      id: form_id,
      class: 'form card-product-qty__form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form',
      data-weight-behavior: weight_behavior,
      data-qty-min: min_q,
      data-qty-increment: inc_q,
      data-qty-max: max_q_str,
      data-variant-cents: v.price,
      data-compare-at-cents: v.compare_at_price,
      data-compare-per-kg: compare_per_kg,
      data-cents-per-kg: cents_per_kg,
      data-currency-with-code: settings.currency_code_enabled,
      data-line-unit-cents: line_unit_cents,
      data-line-weight-cents: line_weight_cents
    -%}
      <input type="hidden" name="id" value="{{ v.id }}" class="product-variant-id" {% if v.available == false %}disabled{% endif %}>
      <input
        type="hidden"
        name="quantity"
        value="{{ min_q }}"
        class="card-product-qty__quantity-hidden"
        autocomplete="off"
      >

      <div class="card-product-qty__line-wrap{% if card_qty_in_media %} visually-hidden{% endif %}" aria-live="polite">
        <span class="card-product-qty__line-label">{{ 'products.product.card_quantity.line_total' | t }}</span>
        <span class="card-product-qty__line-value-wrap">
          {%- if v.compare_at_price > v.price and initial_compare_cents > 0 -%}
            <s class="card-product-qty__line-compare" data-card-line-compare>{{ money_fmt_compare }}</s>
          {%- endif -%}
          <span class="card-product-qty__line-total" data-card-line-total>{{ money_fmt_initial }}</span>
        </span>
      </div>

      {%- if show_weight and show_unit == false -%}
        <input type="hidden" name="purchase_mode" value="weight">
      {%- elsif show_unit and show_weight == false -%}
        <input type="hidden" name="purchase_mode" value="unit">
      {%- endif -%}

      <div class="card-product-qty__bar">
        {%- if show_unit and show_weight -%}
          <div class="card-product-qty__mode card-product-qty__mode--compact" role="group" aria-label="{{ 'products.product.card_quantity.mode_group' | t }}">
            <label class="card-product-qty__mode-label">
              <input type="radio" name="purchase_mode" value="unit" class="card-product-qty__mode-input visually-hidden" checked>
              <span class="card-product-qty__mode-text">{{ 'products.product.card_quantity.by_units_short' | t }}</span>
            </label>
            <label class="card-product-qty__mode-label">
              <input type="radio" name="purchase_mode" value="weight" class="card-product-qty__mode-input visually-hidden">
              <span class="card-product-qty__mode-text">{{ 'products.product.card_quantity.by_weight_short' | t }}</span>
            </label>
          </div>
        {%- endif -%}

        <div class="card-product-qty__bar-panels">
          <div class="card-product-qty__panels">
            {%- if show_unit -%}
              <div class="card-product-qty__panel card-product-qty__panel--unit" data-card-panel="unit">
                <span class="visually-hidden" id="CardQtyUnitLabel-{{ section_id }}-{{ product.id }}">
                  {{- 'products.product.card_quantity.units_label' | t -}}
                </span>
                <quantity-input class="quantity card-product-qty__quantity">
                  <button
                    class="quantity__button"
                    name="minus"
                    type="button"
                    aria-label="{{ 'products.product.card_quantity.decrease_units' | t }}"
                  >
                    <span class="svg-wrapper">{{ 'icon-minus.svg' | inline_asset_content }}</span>
                  </button>
                  <input
                    id="CardQtyUnit-{{ section_id }}-{{ product.id }}"
                    type="number"
                    class="quantity__input js-card-qty-unit"
                    aria-labelledby="CardQtyUnitLabel-{{ section_id }}-{{ product.id }}"
                    min="{{ min_q }}"
                    {% if max_q != null %}max="{{ max_q }}"{% endif %}
                    step="{{ inc_q }}"
                    value="{{ min_q }}"
                    data-min="{{ min_q }}"
                  >
                  <button
                    class="quantity__button"
                    name="plus"
                    type="button"
                    aria-label="{{ 'products.product.card_quantity.increase_units' | t }}"
                  >
                    <span class="svg-wrapper">{{ 'icon-plus.svg' | inline_asset_content }}</span>
                  </button>
                </quantity-input>
              </div>
            {%- endif -%}
            {%- if show_weight -%}
              <div
                class="card-product-qty__panel card-product-qty__panel--weight{% if show_unit %} hidden{% endif %}"
                data-card-panel="weight"
                {% if show_unit %}hidden{% endif %}
              >
                <span class="visually-hidden" id="CardQtyKgLabel-{{ section_id }}-{{ product.id }}">
                  {{- 'products.product.card_quantity.weight_label' | t -}}
                </span>
                <div class="quantity card-product-qty__quantity" data-card-kg-stepper>
                  <button
                    class="quantity__button"
                    type="button"
                    name="kg-minus"
                    aria-label="{{ 'products.product.card_quantity.decrease_kg' | t }}"
                  >
                    <span class="svg-wrapper">{{ 'icon-minus.svg' | inline_asset_content }}</span>
                  </button>
                  <input
                    id="CardQtyKg-{{ section_id }}-{{ product.id }}"
                    type="number"
                    class="quantity__input js-card-qty-kg"
                    aria-labelledby="CardQtyKgLabel-{{ section_id }}-{{ product.id }}"
                    min="0.1"
                    step="0.1"
                    value="1"
                    inputmode="decimal"
                  >
                  <button
                    class="quantity__button"
                    type="button"
                    name="kg-plus"
                    aria-label="{{ 'products.product.card_quantity.increase_kg' | t }}"
                  >
                    <span class="svg-wrapper">{{ 'icon-plus.svg' | inline_asset_content }}</span>
                  </button>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>

        <button
          type="submit"
          name="add"
          class="button button--secondary card-product-qty__submit card-product-qty__submit--icon-only{% if card_qty_in_media %} card-product-qty__submit--bar{% endif %}"
          aria-label="{% if v.available %}{{ 'products.product.add_to_cart' | t | escape }}{% else %}{{ 'products.product.sold_out' | t | escape }}{% endif %}"
          {% if v.available == false %}
            disabled
          {% endif %}
        >
          <span class="card-product-qty__submit-visual">
            <span class="svg-wrapper card-product-qty__cart-icon" aria-hidden="true">
              {{- 'icon-cart.svg' | inline_asset_content -}}
            </span>
            <span id="CardQtySubmit-{{ section_id }}-{{ product.id }}" class="visually-hidden" data-product-form-submit-label>
              {%- if v.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </span>
          </span>
          {%- render 'loading-spinner' -%}
        </button>
      </div>
    {%- endform -%}
  </product-form>
</div>
