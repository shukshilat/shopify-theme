{% comment %}
  Cart drawer — RTL content, LTR host; panel docked left; footer at bottom of panel.
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>

    <div class="drawer__inner cart-drawer__panel">
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          type="button"
          class="drawer__close"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      {% if cart.items.size > 0 %}
        {%- liquid
          comment
            final_line_price של Shopify כבר סכום שורה נכון (כמות × מחיר וריאנט).
            כשהווריאנט מחויר לפי 0.1 ק״ג והכמות בעשיריות — אין לחלק ב-10 (זה שבר תצוגה וסה״כ).
          endcomment
          assign drawer_total_cents = 0
          for item in cart.items
            assign drawer_total_cents = drawer_total_cents | plus: item.final_line_price
          endfor
        -%}
        <form class="cart-drawer__form" action="{{ routes.cart_url }}" method="post" id="CartDrawer-Form">
          <div class="drawer__contents" id="CartDrawer-CartItems">
            <div class="cart-items">
              {% for item in cart.items %}
                {%- liquid
                  assign purchase_mode_prop = item.properties['_purchase_mode'] | default: '' | strip
                  assign weight_qty_unit_kg = item.properties['_weight_qty_unit_kg'] | default: '' | strip

                  comment
                    קודם כל עשיריות ק״ג (0.1): אם נבדוק unit לפני זה, שורה עם _weight_qty_unit_kg
                    נשארת במצב יחידות — שדה number שלם, תצוגה "1" במקום 0.1 ק״ג, בלי אפשרות לערוך עשרוניות.
                  endcomment
                  assign effective_mode = ''
                  if weight_qty_unit_kg == '0.1'
                    assign effective_mode = 'weight'
                  elsif purchase_mode_prop == 'unit'
                    assign effective_mode = 'unit'
                  elsif purchase_mode_prop == 'weight'
                    assign effective_mode = 'weight'
                  elsif item.unit_price_measurement != blank
                    assign ref_u = item.unit_price_measurement.reference_unit | strip | downcase
                    if ref_u == 'kg' or ref_u == 'g'
                      if purchase_mode_prop != 'unit'
                        assign effective_mode = 'weight'
                      endif
                    endif
                  endif
                  if effective_mode == blank
                    assign qty_str = item.quantity | append: ''
                    if qty_str contains '.'
                      assign effective_mode = 'weight'
                    endif
                  endif
                  if effective_mode == blank
                    assign effective_mode = 'unit'
                  endif

                  if weight_qty_unit_kg == '0.1'
                    comment
                      divided_by ב-Liquid מעגל למטה למספר שלם — 6 עשיריות היו הופכות ל-0, 14 ל-1 (נראה כמו ק״ג שלם).
                      times: 0.1 נותן ק״ג אמיתי (0.6, 1.4 וכו׳).
                    endcomment
                    assign cart_qty_display = item.quantity | times: 0.1 | round: 3
                  else
                    assign cart_qty_display = item.quantity
                  endif
                  assign line_display_cents = item.final_line_price
                -%}
                <div
                  class="cart-item"
                  id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                  data-purchase-mode="{{ effective_mode }}"
                  {% if weight_qty_unit_kg == '0.1' %}
                    data-weight-qty-unit-kg="0.1"
                  {% endif %}
                >
                  <img
                    class="cart-item__image"
                    src="{{ item.image | image_url: width: 120 }}"
                    width="70"
                    height="70"
                    loading="lazy"
                    alt="{{ item.image.alt | escape }}"
                  >

                  <div class="cart-item__body">
                    <div style="display:flex;justify-content:space-between;gap:8px;">
                      <span>{{ item.product.title }}</span>
                      <button
                        type="button"
                        class="cart-remove-btn"
                        onclick="removeItem(this, {{ item.index | plus: 1 }})"
                      >
                        ✕
                      </button>
                    </div>

                    <div class="cart-item__price" data-unit-price>
                      {%- if effective_mode == 'weight' and item.unit_price != blank and item.unit_price_measurement != blank -%}
                        {%- comment -%} במשקל: רק מחיר לק״ג מהמוצר — בלי מחיר הווריאנט (למשל ₪2 ל־0.1 ק״ג) {%- endcomment -%}
                        {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                      {%- elsif effective_mode == 'weight' -%}
                        {% if item.original_price != item.final_price %}
                          <s class="cart-item__unit-original">{{ item.original_price | money }}</s>
                          <strong class="cart-item__unit-final">{{ item.final_price | money }}</strong>
                        {% else %}
                          <strong class="cart-item__unit-final">{{ item.original_price | money }}</strong>
                        {% endif %}
                      {%- else -%}
                        {% if item.original_price != item.final_price %}
                          <s class="cart-item__unit-original">{{ item.original_price | money }}</s>
                          <strong class="cart-item__unit-final">{{ item.final_price | money }}</strong>
                        {% else %}
                          <strong class="cart-item__unit-final">{{ item.original_price | money }}</strong>
                        {% endif %}
                        {%- if effective_mode != 'unit' and item.variant.available and item.unit_price != blank and item.unit_price_measurement != blank -%}
                          {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                        {%- endif -%}
                      {%- endif -%}
                    </div>

                    <div class="qty-box qty-box--drawer" data-qty-stepper>
                      <button
                        type="button"
                        class="qty-box__btn"
                        aria-label="{% if effective_mode == 'weight' %}{{ 'products.product.card_quantity.increase_kg' | t }}{% else %}{{ 'products.product.card_quantity.increase_units' | t }}{% endif %}"
                        onclick="changeQty({{ item.index | plus: 1 }}, 1)"
                      >
                        +
                      </button>
                      <input
                        {% if effective_mode == 'weight' %}
                          type="text"
                          inputmode="decimal"
                          autocomplete="off"
                          autocorrect="off"
                          spellcheck="false"
                          class="cart-drawer__qty-weight"
                          onblur="if(window.commitDrawerQtyLine)window.commitDrawerQtyLine({{ item.index | plus: 1 }})"
                          onkeydown="if(event.key==='Enter'){event.preventDefault();if(window.commitDrawerQtyLine)window.commitDrawerQtyLine({{ item.index | plus: 1 }});}"
                        {% else %}
                          type="number"
                          min="1"
                          step="1"
                          autocomplete="off"
                        {% endif %}
                        id="qty-{{ item.index | plus: 1 }}"
                        value="{{ cart_qty_display }}"
                      >
                      <button
                        type="button"
                        class="qty-box__btn"
                        aria-label="{% if effective_mode == 'weight' %}{{ 'products.product.card_quantity.decrease_kg' | t }}{% else %}{{ 'products.product.card_quantity.decrease_units' | t }}{% endif %}"
                        onclick="changeQty({{ item.index | plus: 1 }}, -1)"
                      >
                        −
                      </button>
                    </div>
                  </div>

                  <div class="cart-item__line-total" data-line-price data-line-cents="{{ line_display_cents }}">
                    {{ line_display_cents | money }}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="cart-drawer__sticky-footer">
            <div class="free-shipping-text" style="margin:10px 0;">
              {% if drawer_total_cents >= 15000 %}
                🎉 יש לך משלוח חינם!
              {% else %}
                נשאר לך {{ 15000 | minus: drawer_total_cents | money }} למשלוח חינם 🚚
              {% endif %}
            </div>

            <div class="cart-footer">
              <div class="totals">
                <strong>{{ drawer_total_cents | money }}</strong>
              </div>

              <button type="submit" class="checkout-btn button" name="checkout">
                {{ 'sections.cart.checkout' | t }}
              </button>
            </div>
          </div>
        </form>
      {% else %}
        <p class="cart-drawer__empty" style="margin: 2rem 0; text-align: center;">
          {{ 'sections.cart.empty' | t }}
        </p>
      {% endif %}
    </div>
  </div>
</cart-drawer>

<script>
  (function () {
    const FREE_SHIPPING_THRESHOLD = 15000;

    /** אחרי רענון DOM (replaceWeightLineQuantity) ה-input הישן יתנתק — תמיד לפי שורה. */
    function setDrawerQtyLineLocked(line, locked) {
      var inp = document.getElementById('qty-' + line);
      if (inp) inp.disabled = !!locked;
    }

    function cents(v) {
      var n = Number(v);
      return isNaN(n) ? null : n;
    }

    function formatCartMoney(centsVal) {
      var c = cents(centsVal);
      if (c === null) return '';
      try {
        return new Intl.NumberFormat('he-IL', {
          style: 'currency',
          currency: 'ILS',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(c / 100);
      } catch (e) {
        return (c / 100).toFixed(2) + ' ₪';
      }
    }

    var UNIT_REF_LABELS = {
      kg: 'ק״ג',
      g: 'גרם',
      l: 'ליטר',
      ml: 'מ״ל',
      item: 'יחידה',
      items: 'יחידות',
      ea: 'יחידה',
      pc: 'יחידה',
      pcs: 'יחידות',
    };

    function unitMeasurementLabel(measurement) {
      if (!measurement || !measurement.reference_unit) return '';
      var u = measurement.reference_unit;
      return UNIT_REF_LABELS[u] || u;
    }

    function appendCartDrawerUnitPriceRow(priceWrap, item) {
      var props = item.properties || {};
      var mode = props._purchase_mode || props['_purchase_mode'];
      if (mode === 'unit') return;
      if (item.unit_price == null || item.unit_price === undefined || !item.unit_price_measurement) return;
      var label = unitMeasurementLabel(item.unit_price_measurement);
      if (!label) return;
      var uc = cents(item.unit_price);
      if (uc === null) return;
      priceWrap.insertAdjacentHTML(
        'beforeend',
        '<div class="unit-price unit-price-custom" dir="rtl">' + formatCartMoney(uc) + ' / ' + label + '</div>'
      );
    }

    function cartItemHasTenthsWeightProp(item) {
      var p = item.properties || {};
      return p._weight_qty_unit_kg === '0.1' || p['_weight_qty_unit_kg'] === '0.1';
    }

    /** סכום שורה מ-Shopify; עם תמחור לפי 0.1 ק״ג final_line_price כבר נכון — בלי חלוקה ב-10. */
    function adjustedLineCents(item) {
      var raw = cents(item.final_line_price);
      if (raw === null) return null;
      return raw;
    }

    function cartDisplayTotalCents(cart) {
      if (!cart || !Array.isArray(cart.items)) return null;
      var sum = 0;
      for (var i = 0; i < cart.items.length; i++) {
        var ac = adjustedLineCents(cart.items[i]);
        if (ac === null) return null;
        sum += ac;
      }
      return sum;
    }

    function updateLinePricesFromCart(cart) {
      if (!cart || !Array.isArray(cart.items)) return;

      cart.items.forEach(function (item, index) {
        var line = index + 1;
        var row = document.getElementById('CartDrawer-Item-' + line);
        if (!row) return;

        var lineTotalEl = row.querySelector('[data-line-price]');
        var lineCents = adjustedLineCents(item);
        if (lineTotalEl && lineCents !== null) {
          lineTotalEl.textContent = formatCartMoney(lineCents);
          lineTotalEl.setAttribute('data-line-cents', String(lineCents));
        }

        var priceWrap = row.querySelector('[data-unit-price]');
        if (!priceWrap) return;

        var rowMode = row.getAttribute('data-purchase-mode');
        if (
          rowMode === 'weight' &&
          item.unit_price != null &&
          item.unit_price !== undefined &&
          item.unit_price_measurement
        ) {
          priceWrap.innerHTML = '';
          appendCartDrawerUnitPriceRow(priceWrap, item);
          return;
        }

        var orig = cents(item.original_price);
        var fin = cents(item.final_price);
        if (orig !== null && fin !== null && orig !== fin) {
          priceWrap.innerHTML =
            '<s class="cart-item__unit-original">' +
            formatCartMoney(orig) +
            '</s> <strong class="cart-item__unit-final">' +
            formatCartMoney(fin) +
            '</strong>';
        } else {
          var unit = fin !== null ? fin : orig;
          priceWrap.innerHTML = '<strong class="cart-item__unit-final">' + formatCartMoney(unit) + '</strong>';
        }

        appendCartDrawerUnitPriceRow(priceWrap, item);
      });
    }

    function formatDrawerQtyValueForItem(item) {
      if (!item) return '1';
      var p = item.properties || {};
      var wk = String(p._weight_qty_unit_kg || p['_weight_qty_unit_kg'] || '').trim();
      var q = Number(item.quantity);
      if (!isFinite(q)) return '1';
      if (wk === '0.1') {
        var kg = Math.round((q / 10) * 1000) / 1000;
        var s = kg.toFixed(3).replace(/\.?0+$/, '');
        return s.length ? s : String(kg);
      }
      if (Math.abs(q - Math.round(q)) > 1e-6) {
        var w = Math.round(q * 1000) / 1000;
        var sw = w.toFixed(3).replace(/\.?0+$/, '');
        return sw.length ? sw : String(w);
      }
      return String(Math.round(q));
    }

    /** סנכרון שדות כמות מהעגלה בלי fetch של section — מהיר אחרי cart/change.js */
    function syncDrawerQtyInputsFromCart(cart) {
      if (!cart || !Array.isArray(cart.items)) return;
      var active = document.activeElement;
      cart.items.forEach(function (item, index) {
        var line = index + 1;
        var inp = document.getElementById('qty-' + line);
        if (!inp) return;
        if (active === inp) return;
        inp.value = formatDrawerQtyValueForItem(item);
      });
    }

    function cartChangeUrl() {
      return (window.routes && window.routes.cart_change_url) || '/cart/change.js';
    }

    function cartAddUrl() {
      return (window.routes && window.routes.cart_add_url) || '/cart/add.js';
    }

    function cartJsUrl() {
      return '/cart.js';
    }

    function cloneCartItemProperties(props) {
      if (!props || typeof props !== 'object') return {};
      try {
        return JSON.parse(JSON.stringify(props));
      } catch (e) {
        return {};
      }
    }

    /** Shopify change.js often accepts only integer qty; kg decimals fail — remove line and re-add. */
    function replaceWeightLineQuantity(line, newQty, options) {
      options = options || {};
      return fetch(cartJsUrl())
        .then(function (r) {
          return r.json();
        })
        .then(function (cart) {
          var item = cart.items && cart.items[line - 1];
          if (!item) throw new Error('no line');
          var vid = item.variant_id;
          if (vid == null) throw new Error('no variant');
          var props = cloneCartItemProperties(item.properties);
          var wk = String(props._weight_qty_unit_kg || props['_weight_qty_unit_kg'] || '').trim();
          var hadTenths = wk === '0.1';
          if (options.stripTenthsWeightProp) {
            delete props._weight_qty_unit_kg;
            delete props['_weight_qty_unit_kg'];
          }
          var newQtyNum = Number(newQty);
          if (isNaN(newQtyNum)) throw new Error('bad qty');
          /*
           * עם _weight_qty_unit_kg:0.1 העגלה שומרת כמות בשלמות עשיריות ק״ג (כמו product-form.js).
           * שליחת עשרוני בק״ג בלי המאפיין גורמת ל-Shopify לאכסן 1 — נראה כאיפוס ל-0.1 ק״ג / ₪2.
           */
          var qtyForApi =
            hadTenths && !options.stripTenthsWeightProp
              ? Math.max(1, Math.round(newQtyNum * 10))
              : newQtyNum;
          return fetch(cartChangeUrl(), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line: line, quantity: 0 }),
          }).then(function (res) {
            if (!res.ok) throw new Error('remove failed');
            return fetch(cartAddUrl(), {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                items: [{ id: vid, quantity: qtyForApi, properties: props }],
              }),
            });
          });
        })
        .then(function (res) {
          if (!res.ok) throw new Error('add failed');
          return reloadCartDrawerMarkup();
        });
    }

    var weightTenthsMigrateAttempts = 0;
    function migrateCartTenthsWeightLines() {
      return fetch(cartJsUrl())
        .then(function (r) {
          return r.json();
        })
        .then(function (cart) {
          if (!cart.items || !cart.items.length) return;
          var idx = -1;
          for (var i = cart.items.length - 1; i >= 0; i--) {
            if (cartItemHasTenthsWeightProp(cart.items[i])) {
              idx = i;
              break;
            }
          }
          if (idx < 0) {
            weightTenthsMigrateAttempts = 0;
            return;
          }
          if (weightTenthsMigrateAttempts >= 15) return;
          weightTenthsMigrateAttempts++;
          var line = idx + 1;
          var item = cart.items[idx];
          var kg = Math.round((Number(item.quantity) / 10) * 1000) / 1000;
          if (kg < 0.001) return;
          return replaceWeightLineQuantity(line, kg, { stripTenthsWeightProp: true }).then(function () {
            return migrateCartTenthsWeightLines();
          });
        })
        .catch(function () {});
    }

    function cartTotalCentsForUi(cart) {
      if (!cart) return null;
      var fromApi = cents(cart.total_price);
      if (fromApi !== null) return fromApi;
      return cartDisplayTotalCents(cart);
    }

    function formatKgStepperDisplay(kg) {
      var v = Math.round(Number(kg) * 1000) / 1000;
      if (!isFinite(v)) return String(kg);
      var s = v.toFixed(3).replace(/\.?0+$/, '');
      return s.length ? s : String(v);
    }

    /** עדכון מיידי של שורה + סה״כ + משלוח (יחס קווי) לפני תשובת השרת */
    function optimisticDrawerQtyPreview(line, row, curDisplay, nextDisplay, isWeight) {
      if (!(curDisplay > 0) || !(nextDisplay > 0) || !row) return;
      var lineEl = row.querySelector('[data-line-price]');
      if (!lineEl) return;
      var lc = parseInt(lineEl.getAttribute('data-line-cents'), 10);
      if (!isFinite(lc) || lc < 0) return;
      var ratio = nextDisplay / curDisplay;
      if (!isFinite(ratio)) return;
      var newLc = Math.round(lc * ratio);
      lineEl.setAttribute('data-line-cents', String(newLc));
      lineEl.textContent = formatCartMoney(newLc);

      var totalStrong = document.querySelector('#CartDrawer .totals strong');
      if (totalStrong) {
        var tc = parseInt(totalStrong.getAttribute('data-cart-total-cents'), 10);
        if (isFinite(tc)) {
          var newTc = Math.max(0, tc - lc + newLc);
          totalStrong.setAttribute('data-cart-total-cents', String(newTc));
          totalStrong.textContent = formatCartMoney(newTc);
          var fs = document.querySelector('#CartDrawer .free-shipping-text');
          if (fs) {
            var rem = FREE_SHIPPING_THRESHOLD - newTc;
            if (rem > 0) {
              fs.textContent = '🚚 נשאר לך ' + formatCartMoney(rem) + ' למשלוח חינם';
            } else {
              fs.textContent = '🎉 יש לך משלוח חינם!';
            }
          }
        }
      }

      var inp = document.getElementById('qty-' + line);
      if (inp) {
        inp.value = isWeight ? formatKgStepperDisplay(nextDisplay) : String(Math.round(nextDisplay));
      }
    }

    function syncHeaderCartIcon(cart) {
      if (!cart) return;
      var a = document.getElementById('cart-icon-bubble');
      if (!a) return;
      var count = typeof cart.item_count === 'number' ? cart.item_count : 0;
      var bubble = a.querySelector('.cart-count-bubble');
      if (count < 1) {
        if (bubble) bubble.remove();
        return;
      }
      if (!bubble) {
        bubble = document.createElement('div');
        bubble.className = 'cart-count-bubble';
        a.appendChild(bubble);
      }
      var vis = bubble.querySelector('span[aria-hidden="true"]');
      if (!vis) {
        vis = document.createElement('span');
        vis.setAttribute('aria-hidden', 'true');
        bubble.insertBefore(vis, bubble.firstChild);
      }
      vis.textContent = count < 100 ? String(count) : '';
    }

    function publishCartSync(cart) {
      if (!cart) return;
      syncHeaderCartIcon(cart);
      if (typeof publish === 'function') {
        var ev =
          typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.cartUpdate
            ? PUB_SUB_EVENTS.cartUpdate
            : 'cart-update';
        publish(ev, { source: 'cart-drawer', cartData: cart });
      }
    }

    /** תשובת JSON מ-change.js — בלי round-trip נוסף ל-cart.js כשהתשובה מלאה */
    function postCartChangePayload(payload) {
      return fetch(cartChangeUrl(), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: JSON.stringify(payload),
      }).then(function (res) {
        return res
          .json()
          .catch(function () {
            return null;
          })
          .then(function (json) {
            if (!res.ok) {
              return Promise.reject({ status: res.status, json: json });
            }
            if (json && Array.isArray(json.items)) {
              return json;
            }
            return fetch(cartJsUrl()).then(function (r) {
              return r.json();
            });
          });
      });
    }

    function updateCartUI(cart) {
      var tp = cartTotalCentsForUi(cart);
      var totalEl = document.querySelector('#CartDrawer .totals strong');
      if (totalEl && tp !== null) {
        totalEl.textContent = formatCartMoney(tp);
        totalEl.setAttribute('data-cart-total-cents', String(tp));
      }

      var el = document.querySelector('#CartDrawer .free-shipping-text');
      if (el && tp !== null) {
        var remain = FREE_SHIPPING_THRESHOLD - tp;
        if (remain > 0) {
          el.textContent = '🚚 נשאר לך ' + formatCartMoney(remain) + ' למשלוח חינם';
        } else {
          el.textContent = '🎉 יש לך משלוח חינם!';
        }
      }

      updateLinePricesFromCart(cart);
      syncDrawerQtyInputsFromCart(cart);
      publishCartSync(cart);
    }

    window.removeItem = function (el, line) {
      var itemEl = el.closest('.cart-item');
      if (itemEl) itemEl.style.opacity = '0';

      setTimeout(function () {
        fetch(cartChangeUrl(), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ line: line, quantity: 0 }),
        })
          .then(function () {
            return reloadCartDrawerMarkup();
          })
          .catch(function () {});
      }, 200);
    };

    window.commitDrawerQtyLine = function (line) {
      var input = document.getElementById('qty-' + line);
      if (!input || input.disabled) return;
      var row = input.closest('.cart-item');
      if (!row || row.getAttribute('data-purchase-mode') !== 'weight') return;
      var v = Math.round(parseFloat(String(input.value).replace(',', '.')) * 1000) / 1000;
      if (isNaN(v) || v < 0.001) return;
      var scaledTenths = row.getAttribute('data-weight-qty-unit-kg') === '0.1';
      setDrawerQtyLineLocked(line, true);
      var commitPayload = scaledTenths
        ? { line: line, quantity: Math.max(1, Math.round(v * 10)) }
        : { line: line, quantity: v };

      postCartChangePayload(commitPayload)
        .then(function (cart) {
          updateCartUI(cart);
        })
        .catch(function () {
          return replaceWeightLineQuantity(line, v);
        })
        .catch(function () {
          return fetch(cartJsUrl())
            .then(function (r) {
              return r.json();
            })
            .then(updateCartUI);
        })
        .finally(function () {
          setDrawerQtyLineLocked(line, false);
        });
    };

    window.changeQty = function (line, change) {
      var input = document.getElementById('qty-' + line);
      if (!input || input.disabled) return;

      var row = input.closest('.cart-item');
      var mode = row && row.getAttribute('data-purchase-mode');
      var isWeight = mode === 'weight';
      var unitKgAttr = row && row.getAttribute('data-weight-qty-unit-kg');
      var scaledTenths = isWeight && unitKgAttr === '0.1';
      var step = isWeight ? 0.1 : 1;
      var cur = isWeight
        ? parseFloat(String(input.value).replace(',', '.')) || 0
        : parseInt(input.value, 10) || 0;
      var nextDisplay = Math.round((cur + change * step) * 1000) / 1000;
      if (isWeight) {
        if (nextDisplay < 0.001) return;
      } else {
        nextDisplay = Math.round(nextDisplay);
        if (nextDisplay < 1) return;
      }

      optimisticDrawerQtyPreview(line, row, cur, nextDisplay, isWeight);
      setDrawerQtyLineLocked(line, true);

      var payload = scaledTenths
        ? { line: line, quantity: Math.max(1, Math.round(nextDisplay * 10)) }
        : { line: line, quantity: nextDisplay };

      postCartChangePayload(payload)
        .then(function (cart) {
          updateCartUI(cart);
        })
        .catch(function () {
          if (isWeight) {
            return replaceWeightLineQuantity(line, nextDisplay);
          }
          return fetch(cartJsUrl())
            .then(function (r) {
              return r.json();
            })
            .then(updateCartUI);
        })
        .catch(function () {
          return fetch(cartJsUrl())
            .then(function (r) {
              return r.json();
            })
            .then(updateCartUI);
        })
        .finally(function () {
          setDrawerQtyLineLocked(line, false);
        });
    };

    window.updateCartUIFromCart = updateCartUI;

    function reloadCartDrawerMarkup() {
      var base = (window.routes && window.routes.cart_url) || '/cart';
      return fetch(base + '?section_id=cart-drawer')
        .then(function (r) {
          return r.text();
        })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var next = doc.getElementById('CartDrawer');
          var cur = document.getElementById('CartDrawer');
          if (!next || !cur) return fetch('/cart.js').then(function (r) { return r.json(); });
          cur.innerHTML = next.innerHTML;
          var overlay = document.getElementById('CartDrawer-Overlay');
          var drawer = document.querySelector('cart-drawer');
          if (overlay && drawer && typeof drawer.close === 'function') {
            overlay.onclick = function () {
              drawer.close();
            };
          }
          return fetch('/cart.js').then(function (r) {
            return r.json();
          });
        })
        .then(function (cart) {
          if (cart) {
            var drawer = document.querySelector('cart-drawer');
            if (drawer) {
              drawer.classList.toggle('is-empty', !cart.items || cart.items.length === 0);
            }
            updateCartUI(cart);
          }
        })
        .catch(function () {});
    }

    document.addEventListener('DOMContentLoaded', function () {
      setTimeout(function () {
        migrateCartTenthsWeightLines();
      }, 400);
    });
  })();
</script>
