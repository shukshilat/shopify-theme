{% comment %}
  Cart drawer — RTL content, LTR host; panel docked left; footer at bottom of panel.
{% endcomment %}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>

    <div class="drawer__inner cart-drawer__panel">
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          type="button"
          class="drawer__close"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      {% if cart.items.size > 0 %}
        <form class="cart-drawer__form" action="{{ routes.cart_url }}" method="post" id="CartDrawer-Form">
          <div class="drawer__contents" id="CartDrawer-CartItems">
            <div class="cart-items">
              {% for item in cart.items %}
                <div class="cart-item" id="CartDrawer-Item-{{ item.index | plus: 1 }}">
                  <img
                    class="cart-item__image"
                    src="{{ item.image | image_url: width: 120 }}"
                    width="70"
                    height="70"
                    loading="lazy"
                    alt="{{ item.image.alt | escape }}"
                  >

                  <div>
                    <div style="display:flex;justify-content:space-between;gap:8px;">
                      <span>{{ item.product.title }}</span>
                      <button
                        type="button"
                        class="cart-remove-btn"
                        onclick="removeItem(this, {{ item.index | plus: 1 }})"
                      >
                        ✕
                      </button>
                    </div>

                    <div class="cart-item__price">
                      {% if item.original_price != item.final_price %}
                        <s>{{ item.original_price | money }}</s>
                        <strong>{{ item.final_price | money }}</strong>
                      {% else %}
                        <strong>{{ item.original_price | money }}</strong>
                      {% endif %}
                      {% if item.variant.unit_price %}
                        <div class="unit-price">
                          {{ item.variant.unit_price | money }} / ק״ג
                        </div>
                      {% endif %}
                    </div>

                    <div class="qty-box">
                      <button type="button" onclick="changeQty({{ item.index | plus: 1 }}, 1)">+</button>
                      <input
                        type="number"
                        id="qty-{{ item.index | plus: 1 }}"
                        value="{{ item.quantity }}"
                        min="1"
                      >
                      <button type="button" onclick="changeQty({{ item.index | plus: 1 }}, -1)">−</button>
                    </div>
                  </div>

                  <div>
                    {{ item.final_line_price | money }}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="cart-drawer__sticky-footer">
            <div class="free-shipping-text" style="margin:10px 0;">
              נשאר לך {{ 15000 | minus: cart.total_price | money }} למשלוח חינם 🚚
            </div>

            <div class="cart-footer">
              <div class="totals">
                <strong>{{ cart.total_price | money }}</strong>
              </div>

              <button type="submit" class="checkout-btn button" name="checkout">
                {{ 'sections.cart.checkout' | t }}
              </button>
            </div>
          </div>
        </form>
      {% else %}
        <p class="cart-drawer__empty" style="margin: 2rem 0; text-align: center;">
          {{ 'sections.cart.empty' | t }}
        </p>
      {% endif %}
    </div>
  </div>
</cart-drawer>

<script>
  function updateCartUI(cart) {
    const totalEl = document.querySelector('#CartDrawer .totals strong');
    if (totalEl) {
      totalEl.innerText = (cart.total_price / 100).toLocaleString('he-IL') + ' ₪';
    }

    const el = document.querySelector('#CartDrawer .free-shipping-text');
    if (!el) return;

    const remain = 15000 - cart.total_price;
    if (remain > 0) {
      el.innerText = '🚚 נשאר לך ' + (remain / 100).toFixed(2) + ' ₪ למשלוח חינם';
    } else {
      el.innerText = '🎉 יש לך משלוח חינם!';
    }
  }

  function removeItem(el, line) {
    const itemEl = el.closest('.cart-item');
    itemEl.style.opacity = '0';

    setTimeout(() => {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: 0 }),
      })
        .then(() => fetch('/cart.js'))
        .then((r) => r.json())
        .then((cart) => {
          itemEl.remove();
          updateCartUI(cart);
        });
    }, 200);
  }

  function changeQty(line, change) {
    const input = document.getElementById('qty-' + line);
    let qty = parseInt(input.value, 10) + change;
    if (qty < 1) return;

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty }),
    })
      .then(() => fetch('/cart.js'))
      .then((r) => r.json())
      .then((cart) => {
        input.value = qty;
        updateCartUI(cart);
      });
  }
</script>
